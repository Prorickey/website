---
import Layout from '@/src/layouts/Layout.astro';
import Navbar from '@/components/Navbar';
import BlogPostContent from '@/src/components/blog/BlogPostContent';
import { blogMetadata } from '@/blogs/metadata';

export function getStaticPaths() {
  return Object.keys(blogMetadata).map((name) => ({ params: { name } }));
}

const { name } = Astro.params;
const blog = blogMetadata[name as keyof typeof blogMetadata];

const formatOptions: Intl.DateTimeFormatOptions = {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
};
---

<Layout title={`${blog.title} — Trevor Bedson`} description={blog.description}>
  <Navbar client:load />
  <article
    class="mx-auto my-20 w-1/2 max-w-4xl rounded-2xl bg-stone-950 px-6 py-8"
  >
    <header class="mb-8">
      <h1 class="mb-4 text-4xl font-bold text-gray-200">{blog.title}</h1>
      <div class="mb-6 flex items-center text-gray-300">
        <span>
          Published: {
            new Intl.DateTimeFormat('en-US', formatOptions).format(
              blog.publishedAt
            )
          }
          {
            blog.updatedAt != null &&
              `• Updated: ${new Intl.DateTimeFormat('en-US', formatOptions).format(blog.updatedAt)}`
          }
        </span>
        <span class="mx-2">•</span>
        <span>{blog.readTime} read</span>
      </div>
      <img
        src={blog.image}
        alt={blog.title}
        width={800}
        height={256}
        class="h-96 w-full rounded-lg object-cover shadow-lg"
        loading="lazy"
      />
    </header>
    <BlogPostContent name={name} client:load />
  </article>
</Layout>
